# Minion Meta-Repo — shared non-secret defaults
# Loaded by @minion/env as the lowest-precedence layer.
# Subproject .env.defaults override these values.
# Secrets belong in Infisical, never here.

MINION_META_REPO_ROOT=.
MINION_DEFAULT_INFISICAL_DOMAIN=http://100.80.222.29:8080/api
MINION_DEFAULT_INFISICAL_CORE_PROJECT=minion-core
