# minion-workstation-v1 — reproducible exe.dev workstation image.
#
# exeuntu supplies the provider integration layer (systemd, Docker, Node and
# SSH conventions). The digest pins the exact multi-platform image index.
FROM ghcr.io/boldsoftware/exeuntu@sha256:26ea0bc1d751680557772354f28808bea406b4f19157ea66101882cfd6de554d

USER root
ENV DEBIAN_FRONTEND=noninteractive

ARG SHELLS_BRIDGE_VERSION=0.1.4
ARG HERMES_COMMIT=9de9c25f620ff7f1ce0fd5457d596052d5159596
ARG OPENCODE_VERSION=1.17.18
ARG CLAUDE_CODE_VERSION=2.1.207
ARG PI_VERSION=0.80.6
ARG DRONE_VERSION=0.3.0
ARG MINION_VERSION=2026.7.11-dev
ARG NOTESMD_VERSION=0.3.6
ARG NOTESMD_AMD64_SHA256=e9c484adca59d46365d27a52a6a2e82f2c50b932457bef86e4972c73ccc209c2

# Xfce runs on a private Xvfb display. x11vnc is loopback-only; websockify is
# the sole listener and uses exe.dev's authenticated HTTPS proxy on port 8000.
RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates curl dbus-x11 git python3 python3-pip python3-venv \
      xfce4 xfce4-terminal xvfb x11vnc novnc websockify rclone tar sudo \
  && rm -rf /var/lib/apt/lists/*

RUN id agent >/dev/null 2>&1 || useradd --create-home --shell /bin/bash agent \
  && echo "agent ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/agent \
  && chmod 0440 /etc/sudoers.d/agent \
  && install -d -o agent -g agent /home/agent/state /home/agent/workspace

# Agent tools are pinned. SHELLS_RUNTIMES controls which tools the Hub exposes;
# baking them once keeps later VM creation independent of mutable installers.
RUN npm install --global \
      "@minion-stack/shells-bridge@${SHELLS_BRIDGE_VERSION}" \
      "opencode-ai@${OPENCODE_VERSION}" \
      "@anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}" \
      "@earendil-works/pi-coding-agent@${PI_VERSION}" \
      "@minion-stack/drone@${DRONE_VERSION}" \
      "@nikolasp98/minion@${MINION_VERSION}"

RUN python3 -m venv /opt/hermes-agent \
  && /opt/hermes-agent/bin/pip install --no-cache-dir \
       "git+https://github.com/NousResearch/hermes-agent.git@${HERMES_COMMIT}"

RUN curl -fsSL \
      "https://github.com/Yakitrak/notesmd-cli/releases/download/v${NOTESMD_VERSION}/notesmd-cli_${NOTESMD_VERSION}_linux_amd64.tar.gz" \
      -o /tmp/notesmd-cli.tar.gz \
  && echo "${NOTESMD_AMD64_SHA256}  /tmp/notesmd-cli.tar.gz" | sha256sum -c - \
  && tar -xzf /tmp/notesmd-cli.tar.gz -C /usr/local/bin notesmd-cli \
  && chmod 0755 /usr/local/bin/notesmd-cli \
  && rm -f /tmp/notesmd-cli.tar.gz

COPY shells-bridge.service /etc/systemd/system/shells-bridge.service
COPY minion-x-display.service /etc/systemd/system/minion-x-display.service
COPY minion-desktop.service /etc/systemd/system/minion-desktop.service
COPY minion-vnc.service /etc/systemd/system/minion-vnc.service
COPY minion-novnc.service /etc/systemd/system/minion-novnc.service

RUN systemctl enable \
      shells-bridge.service \
      minion-x-display.service \
      minion-desktop.service \
      minion-vnc.service \
      minion-novnc.service \
  && chown -R agent:agent /home/agent

LABEL org.opencontainers.image.title="Minion Workstation" \
      org.opencontainers.image.description="exe.dev Xfce/noVNC workstation for Minion orgs" \
      minion.blueprint="minion-workstation-v1" \
      minion.desktop="xfce" \
      minion.gui.transport="novnc" \
      minion.gui.port="8000"

EXPOSE 8000
STOPSIGNAL SIGRTMIN+3
CMD ["/sbin/init"]
