# claude-code-shell-v1 — Claude Code CLI running inside an exe.dev VM,
# wired through the shells-bridge via ACP/JSON-RPC over stdio.
#
# Build:
#   docker buildx build -f Dockerfile.claude-code -t minionstack/claude-code-shell:v1 .
#   docker push minionstack/claude-code-shell:v1
#
# Use:
#   ssh exe.dev new --image=minionstack/claude-code-shell:v1 --name=<name> \
#     --env=SHELLS_SHELL_ID=... --env=SHELLS_GATEWAY_URL=... \
#     --env=SHELLS_DEVICE_TOKEN=... --env=SHELLS_HARNESS=claude-code \
#     --env=SHELLS_HARNESS_VERSION=2026.05 \
#     --env=SHELLS_HARNESS_CMD="claude code --acp" \
#     --env=ANTHROPIC_API_KEY=... \
#     --env=SHELLS_BACKUP_TARGET="b2://minion-shells/<shellId>/"

FROM minionstack/shells-bridge-base:v1

# Claude Code CLI via npm.
ARG CLAUDE_CODE_VERSION=latest
RUN npm install --global "@anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}"

USER root
LABEL minion.harness="claude-code" \
      minion.bridge.version="0.1.0" \
      org.opencontainers.image.source="https://github.com/NikolasP98/minion-meta"

RUN mkdir -p /home/agent/state /home/agent/.claude \
  && chown -R agent:agent /home/agent/state /home/agent/.claude
