{
  "name": "@minion-stack/shared",
  "version": "0.4.0",
  "description": "Shared gateway protocol types and utilities for the Minion platform.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NikolasP98/minion-meta.git",
    "directory": "packages/shared"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./gateway": {
      "types": "./dist/gateway/index.d.ts",
      "import": "./dist/gateway/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    }
  },
  "peerDependencies": {
    "ws": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src"
  },
  "devDependencies": {
    "@minion-stack/tsconfig": "workspace:*",
    "@types/ws": "^8.18.1",
    "oxlint": ">=0.15.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9",
    "ws": "^8.19.0"
  }
}
