  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.test.json"
  },
  "devDependencies": {
    "@minion-stack/tsconfig": "workspace:*",
    "@types/node": "^22.19.17",
    "tsdown": "^0.21.9",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
