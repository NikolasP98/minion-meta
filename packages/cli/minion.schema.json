{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/NikolasP98/minion-meta/packages/cli/minion.schema.json",
  "title": "Minion subproject registry",
  "type": "object",
  "required": ["subprojects"],
  "properties": {
    "$schema": { "type": "string" },
    "subprojects": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/subproject" }
    }
  },
  "definitions": {
    "subproject": {
      "type": "object",
      "required": ["path", "packageManager", "branch", "infisicalProject", "remote", "commands"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "packageManager": { "type": "string", "enum": ["pnpm", "bun", "npm", "yarn"] },
        "branch": { "type": "string", "minLength": 1 },
        "infisicalProject": { "type": "string", "pattern": "^minion-[a-z0-9-]+$" },
        "remote": { "type": "string", "minLength": 1 },
        "commands": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
