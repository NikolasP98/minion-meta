{
  "name": "@minion-stack/crm-sdk",
  "version": "0.1.0",
  "description": "Typed server-side SDK for the Minion CRM party spine — lead upsert + PERUDEVS DNI identity validation over the shared Supabase Postgres.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NikolasP98/minion-meta.git",
    "directory": "packages/crm-sdk"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src"
  },
  "peerDependencies": {
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@minion-stack/tsconfig": "workspace:*",
    "@types/node": "^22.19.17",
    "oxlint": "^1.66.0",
    "postgres": "^3.4.9",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
