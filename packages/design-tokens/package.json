{
  "name": "@minion-stack/design-tokens",
  "version": "0.1.0",
  "description": "Generated semantic design-token contract shared across the Minion platform.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NikolasP98/minion-meta.git",
    "directory": "packages/design-tokens"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "contract.json",
    "contract.schema.json",
    "tokens.css",
    "utilities.css",
    "README.md"
  ],
  "exports": {
    "./contract.json": "./contract.json",
    "./contract.schema.json": "./contract.schema.json",
    "./tokens.css": "./tokens.css",
    "./utilities.css": "./utilities.css"
  },
  "scripts": {
    "generate": "node scripts/generate-css.mjs",
    "check:generated": "node scripts/generate-css.mjs --check",
    "build": "pnpm run check:generated && pnpm run test",
    "typecheck": "pnpm run check:generated",
    "test": "node --test tests/*.test.mjs"
  }
}
