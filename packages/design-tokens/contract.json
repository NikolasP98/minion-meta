{
  "$schema": "./contract.schema.json",
  "contractVersion": "1.0.0",
  "defaultTheme": "new-york",
  "description": "Machine-readable semantic design contract for Minion products.",
  "foundations": {
    "fonts": {
      "--font-family-sans": "'Inter', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "--font-family-mono": "'JetBrains Mono NF', 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace",
      "--font-family-display": "'Plus Jakarta Sans', 'Inter', ui-sans-serif, system-ui, sans-serif"
    },
    "fontSizes": {
      "--font-size-display": "28px",
      "--font-size-page-title": "18px",
      "--font-size-section-title": "14px",
      "--font-size-body": "14px",
      "--font-size-label": "12px",
      "--font-size-caption": "12px",
      "--font-size-mono": "12px",
      "--font-size-telemetry": "10px"
    },
    "lineHeights": {
      "--line-height-display": "36px",
      "--line-height-heading": "24px",
      "--line-height-body": "20px",
      "--line-height-compact": "16px",
      "--line-height-mono": "18px"
    },
    "fontWeights": {
      "--font-weight-regular": "400",
      "--font-weight-medium": "500",
      "--font-weight-semibold": "600",
      "--font-weight-bold": "700"
    },
    "letterSpacing": {
      "--letter-spacing-normal": "0",
      "--letter-spacing-label": "0.04em",
      "--letter-spacing-display": "-0.01em"
    },
    "spacing": {
      "--space-0": "0px",
      "--space-0-5": "2px",
      "--space-1": "4px",
      "--space-2": "8px",
      "--space-3": "12px",
      "--space-4": "16px",
      "--space-6": "24px",
      "--space-8": "32px",
      "--space-12": "48px",
      "--space-control-gap": "8px",
      "--space-field-gap": "8px",
      "--space-card-compact": "12px",
      "--space-card": "16px",
      "--space-section": "24px",
      "--space-page-section": "32px",
      "--space-page-gutter": "16px"
    },
    "controlSizes": {
      "--control-height-xs": "24px",
      "--control-height-sm": "28px",
      "--control-height-md": "32px",
      "--control-height-lg": "36px",
      "--control-height-touch": "44px"
    },
    "iconSizes": {
      "--icon-size-xs": "12px",
      "--icon-size-sm": "14px",
      "--icon-size-md": "16px",
      "--icon-size-lg": "20px"
    },
    "motion": {
      "--duration-instant": "75ms",
      "--duration-fast": "150ms",
      "--duration-normal": "250ms",
      "--duration-slow": "400ms",
      "--ease-standard": "cubic-bezier(0.2, 0, 0, 1)",
      "--ease-enter": "cubic-bezier(0, 0, 0.2, 1)",
      "--ease-exit": "cubic-bezier(0.4, 0, 1, 1)",
      "--ease-spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "layers": {
      "--layer-base": "0",
      "--layer-sticky": "10",
      "--layer-navigation": "20",
      "--layer-dropdown": "30",
      "--layer-popover": "40",
      "--layer-modal": "50",
      "--layer-toast": "60",
      "--layer-command": "70",
      "--layer-debug": "100"
    },
    "layout": {
      "--shell-sidebar-collapsed": "56px",
      "--shell-sidebar-expanded": "224px",
      "--section-nav-expanded": "208px",
      "--page-header-height": "56px",
      "--notch-clearance": "96px"
    }
  },
  "responsive": {
    "compactMax": "767px",
    "mediumMin": "768px",
    "wideMin": "1280px",
    "pageGutter": {
      "compact": "16px",
      "medium": "24px",
      "wide": "32px"
    }
  },
  "typographyStyles": {
    "standard": {
      "--theme-letter-spacing": "0em",
      "--theme-line-height": "1.5",
      "--theme-font-weight": "400"
    },
    "airy": {
      "--theme-letter-spacing": "0.015em",
      "--theme-line-height": "1.6",
      "--theme-font-weight": "400"
    },
    "wide": {
      "--theme-letter-spacing": "0.06em",
      "--theme-line-height": "1.6",
      "--theme-font-weight": "400"
    }
  },
  "radiusScales": {
    "standard": {
      "--radius-xs": "2px",
      "--radius-sm": "4px",
      "--radius-md": "6px",
      "--radius-lg": "8px",
      "--radius-xl": "12px",
      "--radius-full": "9999px"
    },
    "soft": {
      "--radius-xs": "3px",
      "--radius-sm": "5px",
      "--radius-md": "8px",
      "--radius-lg": "10px",
      "--radius-xl": "14px",
      "--radius-full": "9999px"
    },
    "square": {
      "--radius-xs": "0px",
      "--radius-sm": "0px",
      "--radius-md": "0px",
      "--radius-lg": "0px",
      "--radius-xl": "0px",
      "--radius-full": "0px"
    }
  },
  "shadowStyles": {
    "dark": {
      "--shadow-elevation-1": "0 1px 2px rgba(0, 0, 0, 0.3)",
      "--shadow-elevation-2": "0 4px 12px rgba(0, 0, 0, 0.4)",
      "--shadow-elevation-3": "0 8px 24px rgba(0, 0, 0, 0.5)",
      "--shadow-elevation-4": "0 16px 48px rgba(0, 0, 0, 0.6)",
      "--shadow-overlay": "0 24px 72px rgba(0, 0, 0, 0.65)",
      "--shadow-focus": "0 0 0 3px color-mix(in srgb, var(--color-accent) 35%, transparent)",
      "--shadow-status-glow": "0 0 16px color-mix(in srgb, currentColor 24%, transparent)"
    },
    "light": {
      "--shadow-elevation-1": "0 1px 2px rgba(15, 23, 42, 0.08)",
      "--shadow-elevation-2": "0 4px 12px rgba(15, 23, 42, 0.1)",
      "--shadow-elevation-3": "0 8px 24px rgba(15, 23, 42, 0.14)",
      "--shadow-elevation-4": "0 16px 48px rgba(15, 23, 42, 0.18)",
      "--shadow-overlay": "0 24px 72px rgba(15, 23, 42, 0.24)",
      "--shadow-focus": "0 0 0 3px color-mix(in srgb, var(--color-accent) 30%, transparent)",
      "--shadow-status-glow": "0 0 12px color-mix(in srgb, currentColor 18%, transparent)"
    }
  },
  "statusRecipes": {
    "dark": {
      "success": { "fg": "#4ade80", "surface": "#052e16", "border": "#166534" },
      "warning": { "fg": "#fbbf24", "surface": "#451a03", "border": "#92400e" },
      "danger": { "fg": "#fca5a5", "surface": "#450a0a", "border": "#991b1b" },
      "info": { "fg": "#93c5fd", "surface": "#172554", "border": "#1e40af" }
    },
    "light": {
      "success": { "fg": "#166534", "surface": "#dcfce7", "border": "#86efac" },
      "warning": { "fg": "#854d0e", "surface": "#fef3c7", "border": "#fcd34d" },
      "danger": { "fg": "#991b1b", "surface": "#fee2e2", "border": "#fca5a5" },
      "info": { "fg": "#1e40af", "surface": "#dbeafe", "border": "#93c5fd" }
    }
  },
  "accentOptions": {
    "blue": { "accent": "#3b82f6", "onAccent": "#09090b" },
    "purple": { "accent": "#a855f7", "onAccent": "#09090b" },
    "green": { "accent": "#22c55e", "onAccent": "#09090b" },
    "cyan": { "accent": "#06b6d4", "onAccent": "#09090b" },
    "rose": { "accent": "#f43f5e", "onAccent": "#09090b" },
    "amber": { "accent": "#f59e0b", "onAccent": "#09090b" },
    "orange": { "accent": "#f97316", "onAccent": "#09090b" },
    "emerald": { "accent": "#10b981", "onAccent": "#09090b" },
    "indigo": { "accent": "#5f62e6", "onAccent": "#ffffff" },
    "red": { "accent": "#ef4444", "onAccent": "#09090b" }
  },
  "palettes": {
    "--color-purple": "#a855f7",
    "--color-pink": "#ec4899",
    "--color-cyan": "#06b6d4",
    "--color-emerald": "#10b981",
    "--color-neutral": "#64748b"
  },
  "themes": {
