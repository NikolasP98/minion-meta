{
  "name": "@minion-stack/auth",
  "version": "0.2.0",
  "description": "Better Auth factory for the Minion platform — shared between minion_hub and minion_site.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NikolasP98/minion-meta.git",
    "directory": "packages/auth"
  },
  "type": "module",
  "main": "./dist/index.js",
