    "better-auth": "1.4.19",
    "drizzle-orm": ">=0.45.0"
  },
  "devDependencies": {
    "@minion-stack/tsconfig": "workspace:*",
    "@minion-stack/db": "workspace:*",
    "better-auth": "1.4.19",
    "drizzle-orm": "^0.45.1",
    "oxlint": ">=0.15.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.9"
  }
