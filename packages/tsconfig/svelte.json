{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@minion-stack/tsconfig/svelte",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "allowJs": true,
    "checkJs": false,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "target": "ES2022"
  }
}
