{
  "name": "@minion-stack/ui",
  "version": "0.1.0",
  "description": "Shared Svelte 5 UI primitives for the Minion platform — token-driven Button, Badge, Card, Input.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NikolasP98/minion-meta.git",
    "directory": "packages/ui"
  },
  "type": "module",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "svelte-package",
    "prepublishOnly": "svelte-package",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json"
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "lucide-svelte": ">=0.400.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.3.7",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte": "^5.55.9",
    "svelte-check": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
