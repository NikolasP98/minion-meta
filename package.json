{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@nikolasp98/minion-root",
  "version": "0.0.0",
  "private": true,
  "description": "Minion meta-repo — orchestration, shared packages, specs. See specs/2026-04-19-minion-meta-repo-design.md.",
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "changeset": "changeset",
    "changeset:status": "changeset status --since=origin/main",
    "release:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0"
  }
}
